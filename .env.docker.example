# Copy to .env in this folder and adjust. Used by: docker compose up --build

JWT_SECRET=replace-with-openssl-rand-hex-32
GROQ_API_KEY=

# Browser calls this URL (host machine). Default matches published ports in docker-compose.yml.
NEXT_PUBLIC_API_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Malware gRPC (compose service `malware` listens on 50052; backend default MALWARE_GRPC_URL=malware:50052).
# MALWARE_GRPC_URL=malware:50052
# MALWARE_GRPC_TIMEOUT_MS=30000
# MALWARE_GRPC_RETRIES=2
