# ─────────────────────────────────────────────────────────────────────────────
# SecureMail — ROOT environment file
# HOW TO USE:
#   cp .env.example .env
#   OR just run: ./setup.sh (Mac/Linux) | setup.bat (Windows)
#
# This file is read by the ROOT docker-compose.yml for variable substitution.
# Each service also has its own .env.docker inside its folder.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (single source of truth) ────────────────────────────────────────
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_DB=securemail
POSTGRES_USER=postgres
